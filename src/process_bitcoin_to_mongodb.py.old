import os # For file path handling
import pandas as pd # For data manipulation
from pymongo import MongoClient # For MongoDB connection
from tqdm import tqdm # For the progress bar during MongoDB insertion

def process_bitcoin():
    """
    Cleans and transforms raw Bitcoin historical data and saves to MongoDB.
    Includes a real-time progress bar for database injection.
    """
    print("--- Starting Bitcoin Data Transformation (MongoDB) ---")
    
    # Path Configuration
    raw_file = os.path.join('..', 'data', 'raw', 'bitcoin', 'bitcoin_historical_data.csv')
    
    if not os.path.exists(raw_file):
        print(f" ❌ Error: Bitcoin raw file not found at {raw_file}")
        return

    # 1. Load Data
    print(" - Loading CSV...")
    df = pd.read_csv(raw_file)

    # 2. Handle Timestamps
    if 'timestamp' in df.columns:
        print(" - Converting Unix timestamps to datetime objects...")
        df['timestamp'] = pd.to_datetime(df['timestamp'], unit='s')
    
    # 3. Handle Null Values
    null_count = df.isnull().any(axis=1).sum()
    if null_count > 0:
        print(f" - Found {null_count:,} rows with missing values. Dropping them...")
        df = df.dropna()

    # 4. Save to MongoDB
    total_records = len(df)
    print(f" - Preparing {total_records:,} records for MongoDB...")
    print(f" - Time range: {df['timestamp'].min()} to {df['timestamp'].max()}")
    
    try:
        # Connect to MongoDB container
        client = MongoClient('mongodb://mongodb:27017/')
        db = client['cryptoflash_db']
        collection = db['bitcoin_history']

        # Clear old records to ensure data freshnees
        print(" - Clearing old records in 'bitcoin_history'...")
        collection.delete_many({})

        # Convert DataFrame to dictionary list (JSON format for Mongo)
        print(" - Converting to records format...")
        data_dict = df.to_dict('records')

        # 5. Chunked Insertion with Progress Bar
        chunk_size = 100000
        
        # tqdm creates the bar. 'unit' and 'desc' provide context in the terminal.
        with tqdm(total=total_records, desc="💾 Injecting Bitcoin Data", unit="rows") as pbar:
            for i in range(0, total_records, chunk_size):
                chunk = data_dict[i:i + chunk_size]
                collection.insert_many(chunk)
                
                # Update bar based on actual chunk size (handling the final smaller chunk)
                pbar.update(len(chunk))

        print(f" ✅ MongoDB injection complete. Collection: {collection.full_name}")
        
    except Exception as e:
        print(f" ❌ MongoDB Error: {e}")
    finally:
        client.close()

if __name__ == "__main__":
    process_bitcoin()