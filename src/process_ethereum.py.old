import os
import pandas as pd

def process_ethereum():
    """
    Cleans and transforms raw Ethereum historical data.
    Source: viniciusqroz/ethereum-historical-data (Daily/Hourly)
    """
    print("--- Starting Ethereum Data Transformation ---")
    
    # Path Configuration
    raw_file = os.path.join('..', 'data', 'raw', 'ethereum', 'ethereum_historical_data.csv')
    output_dir = os.path.join('..', 'data', 'processed', 'ethereum')
    os.makedirs(output_dir, exist_ok=True)
    
    if not os.path.exists(raw_file):
        print(f" ❌ Error: Ethereum raw file not found at {raw_file}")
        return

    # 1. Load Data
    print(" - Loading Ethereum CSV...")
    df = pd.read_csv(raw_file)

    # 2. Standardize Column Names
    # Ethereum datasets sometimes use 'date' (string) instead of 'timestamp' (Unix)
    if 'date' in df.columns:
        print(" - Converting 'Date' strings to datetime objects...")
        df['timestamp'] = pd.to_datetime(df['date'])
        # Drop the old string column to keep schema clean
        df = df.drop(columns=['date'])
    
    # 3. Consistency Check
    # Ensure columns are ordered with Timestamp first
    cols = ['timestamp'] + [c for c in df.columns if c != 'timestamp']
    df = df[cols]

    # 4. Final Metadata Check
    print(f" - Total rows processed: {len(df):,}")
    print(f" - Time range: {df['timestamp'].min()} to {df['timestamp'].max()}")

    # 5. Save as Parquet
    output_path = os.path.join(output_dir, 'ethereum_cleaned.parquet')
    df.to_parquet(output_path, index=False)
    print(f" ✅ Ethereum processing complete. Saved to: {output_path}")

if __name__ == "__main__":
    process_ethereum()